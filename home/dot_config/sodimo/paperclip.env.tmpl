# Paperclip — Sodimo config
# =============================================================================
# Upstream: paperclipai/paperclip (MIT), docs at https://docs.paperclip.ing
# Image: UPSTREAM ghcr.io/paperclipai/paperclip:sha-b8725c5 (v2026.416.0),
# pinned in paperclip.container. Derived image with @mariozechner/pi blocked
# on sodimo/dotfiles#12 (publish auth).
#
# 2026-05-05: PAPERCLIP_PUBLIC_URL pinned to LAN IP 192.168.0.134:3111 so
# Windows colleagues without Tailscale can hit the demo from the office LAN
# (same posture as Twenty CRM). The hostname allowlist is widened to cover
# LAN IP + tailnet hostname + future cloudflared FQDN, so the URL flip
# back to https://paperclip.sodimo.eu is a one-line change.
#
# REVERT WHEN crm.sodimo.eu / paperclip.sodimo.eu GO LIVE: set PUBLIC_URL
# back to https://paperclip.sodimo.eu. Allowlist already includes it.
# CF Access gates the hostname at the Cloudflare edge once cloudflared is up;
# inside, Paperclip runs in its default `authenticated` deployment mode.
# First admin is bootstrapped out-of-band with
#   paperclipai auth bootstrap-ceo --data-dir /paperclip --base-url <PUBLIC_URL>

# --- Server binding ----------------------------------------------------------
HOST=0.0.0.0
PORT=3100
SERVE_UI=true

# --- Paperclip runtime -------------------------------------------------------
PAPERCLIP_HOME=/paperclip
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_PUBLIC_URL=http://192.168.0.134:3111
# Allowlist matches the request Host header VERBATIM, but Paperclip strips the
# port before matching — values must be HOSTNAME ONLY (no :3111 suffix), or
# the runtime returns a self-describing 403. Verified empirically 2026-05-05;
# `paperclipai allowed-hostname <h>` reports the bare hostname in its error.
# Allow LAN IP, tailnet IP/name, localhost, and the future cloudflared FQDN.
PAPERCLIP_ALLOWED_HOSTNAMES=192.168.0.134,sodimo,100.84.46.98,localhost,paperclip.sodimo.eu

# --- Telemetry opt-out -------------------------------------------------------
PAPERCLIP_TELEMETRY_DISABLED=1
DO_NOT_TRACK=1

# --- Postgres ----------------------------------------------------------------
# paperclip-db container on sodimo.network; password replaced at chezmoi apply.
DATABASE_URL=postgres://paperclip:CHANGEME-DB-PASSWORD@paperclip-db:5432/paperclip

# --- Secrets -----------------------------------------------------------------
# 32-byte hex, replaced at chezmoi apply time. Loss of this key means loss of
# every encrypted secret in the Paperclip DB.
PAPERCLIP_SECRETS_MASTER_KEY=CHANGEME-32-BYTE-HEX

# BetterAuth session signing key. Paperclip refuses to start without this
# (validated in task #7 smoke 2026-04-22). 32-byte hex; rotating invalidates
# all active sessions.
BETTER_AUTH_SECRET=CHANGEME-BETTER-AUTH-32-BYTE-HEX

# BetterAuth's origin check is EXACT-STRING (full URL incl. port). Paperclip's
# allowlist-derivation only adds bare-hostname forms (`http://sodimo`) plus the
# PUBLIC_URL with port (`http://192.168.0.134:3111`); requests originating from
# any other host:port pair (`http://sodimo:3111`, `http://100.84.46.98:3111`)
# get `ERROR [Better Auth]: Invalid origin` → 403 on every /api/auth/* call.
# Empirical fix 2026-05-05: list every host:port the demo will actually receive
# requests from, comma-separated. Re-derive when production cloudflared lands.
BETTER_AUTH_TRUSTED_ORIGINS=http://192.168.0.134:3111,http://sodimo:3111,http://100.84.46.98:3111,http://localhost:3111,https://paperclip.sodimo.eu

# --- LLM routing through LiteLLM --------------------------------------------
# All Anthropic + OpenAI traffic from Paperclip agents (claude-code, pi-mono)
# is routed through the in-cluster LiteLLM gateway for token accounting,
# fallback and cost caps (Principle 2). No direct cloud credentials live here.
ANTHROPIC_BASE_URL=http://litellm:4000
ANTHROPIC_API_KEY=CHANGEME-LITELLM-MASTER-KEY
OPENAI_BASE_URL=http://litellm:4000
OPENAI_API_KEY=CHANGEME-LITELLM-MASTER-KEY
LITELLM_MASTER_KEY=CHANGEME-LITELLM-MASTER-KEY
