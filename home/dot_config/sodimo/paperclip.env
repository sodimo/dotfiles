# Paperclip — Sodimo config
# =============================================================================
# Upstream: paperclipai/paperclip (MIT), docs at https://docs.paperclip.ing
# Image: derived from ghcr.io/paperclipai/paperclip:sha-b8725c5 (v2026.416.0)
# with @mariozechner/pi layered on top (see docker/paperclip/Dockerfile).
#
# Access posture mirrors OpenWebUI: CF Access gates paperclip.sodimo.eu at
# the Cloudflare edge; inside, Paperclip runs in its default `authenticated`
# deployment mode. First admin is bootstrapped via BetterAuth /api/auth/sign-up.
#
# 2026-05-05 demo-day note: on the live box, PAPERCLIP_PUBLIC_URL is
# overridden to http://192.168.0.134:3111 so Windows colleagues without
# Tailscale can reach the office demo from the LAN. The override is
# deployed-only; the repo keeps the production-shape URL so chezmoi update
# does NOT flip a running cloudflared deployment back to LAN.
# A commented LAN line is included below for one-line revert if needed.

# --- Server binding ----------------------------------------------------------
HOST=0.0.0.0
PORT=3100
SERVE_UI=true

# --- Paperclip runtime -------------------------------------------------------
PAPERCLIP_HOME=/paperclip
PAPERCLIP_INSTANCE_ID=default
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_PUBLIC_URL=https://paperclip.sodimo.eu
# PAPERCLIP_PUBLIC_URL=http://192.168.0.134:3111

# Allowlist matches the request Host header VERBATIM and Paperclip strips the
# port before matching — values must be HOSTNAME ONLY (no :3111 suffix), or
# the runtime returns a self-describing 403. Verified 2026-05-05.
# Superset includes future cloudflared FQDN, LAN IP, tailnet hostname/IP,
# and localhost so URL flips never break either path.
PAPERCLIP_ALLOWED_HOSTNAMES=paperclip.sodimo.eu,192.168.0.134,sodimo,100.84.46.98,localhost

# BetterAuth's origin check is EXACT-STRING (full URL incl. port). Every
# host:port pair the demo will receive requests from must be listed.
BETTER_AUTH_TRUSTED_ORIGINS=https://paperclip.sodimo.eu,http://192.168.0.134:3111,http://sodimo:3111,http://100.84.46.98:3111,http://localhost:3111

# --- Telemetry opt-out -------------------------------------------------------
PAPERCLIP_TELEMETRY_DISABLED=1
DO_NOT_TRACK=1

# --- Postgres ----------------------------------------------------------------
# paperclip-db container on sodimo.network; password replaced at deploy time
# via `vault-fetch paperclip` (issue #25).
DATABASE_URL=postgres://paperclip:CHANGEME-DB-PASSWORD@paperclip-db:5432/paperclip

# --- Secrets -----------------------------------------------------------------
# 32-byte hex, replaced at deploy time. Loss of this key means loss of every
# encrypted secret in the Paperclip DB.
PAPERCLIP_SECRETS_MASTER_KEY=CHANGEME-32-BYTE-HEX

# BetterAuth session signing key. Paperclip refuses to start without this.
# 32-byte hex; rotating invalidates all active sessions.
BETTER_AUTH_SECRET=CHANGEME-BETTER-AUTH-32-BYTE-HEX

# --- LLM routing through LiteLLM --------------------------------------------
# All Anthropic + OpenAI traffic from Paperclip agents (claude-code, pi-mono)
# is routed through the in-cluster LiteLLM gateway for token accounting,
# fallback and cost caps (Principle 2). No direct cloud credentials live here.
ANTHROPIC_BASE_URL=http://litellm:4000
ANTHROPIC_API_KEY=CHANGEME-LITELLM-MASTER-KEY
OPENAI_BASE_URL=http://litellm:4000
OPENAI_API_KEY=CHANGEME-LITELLM-MASTER-KEY
LITELLM_MASTER_KEY=CHANGEME-LITELLM-MASTER-KEY
