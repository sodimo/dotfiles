# Vaultwarden — Sodimo posture
# =============================================================================
# DO NOT COMMIT REAL VALUES. This file is a SHAPE reference with CHANGEME-*
# placeholders. chezmoi does NOT apply this file to the box (.chezmoiignore
# excludes ~/.config/sodimo/vaultwarden.env). On the box: ~/.config/sodimo/
# vaultwarden.env holds real secrets (mode 0600), populated by `vault-fetch
# vaultwarden` from Vaultwarden itself after first admin login.
#
# Bootstrap exception: ADMIN_TOKEN cannot be retrieved from Vaultwarden until
# Vaultwarden is running. The first ADMIN_TOKEN is generated at deploy time,
# stored in ~/.config/sodimo/vaultwarden.env on the box, and a paper copy
# goes to the office safe per chapter 38 (master operator holds it). Once
# Vaultwarden is up, the value also lives under sodimo/vaultwarden/ADMIN_TOKEN
# in Vaultwarden itself — that becomes the canonical digital record.
#
# Demo posture: LAN + Tailscale only, http://192.168.0.134:8222.
# REVERT WHEN vault.sodimo.eu GOES LIVE: uncomment the https://vault.sodimo.eu
# DOMAIN line below, comment the LAN one, set INVITATIONS_ALLOWED=true,
# uncomment the SMTP_* block. CF Access gates the hostname.

DOMAIN=http://192.168.0.134:8222
# DOMAIN=https://vault.sodimo.eu

# --- ADMIN UI (gated by ADMIN_TOKEN; reachable at /admin) -------------------
# Initial value: `openssl rand -hex 32` at deploy time.
# After bring-up, replace with an Argon2 PHC string for quieter logs (clears
# the `[NOTICE] You are using a plain text ADMIN_TOKEN ...` line at startup):
#   podman exec vaultwarden /vaultwarden hash
#     ↑ produces a $argon2id$... PHC string; paste it as ADMIN_TOKEN below
# The plaintext copy goes on paper to the office safe (chapter 38).
# See: https://github.com/dani-garcia/vaultwarden/wiki/Enabling-admin-page#secure-the-admin_token
ADMIN_TOKEN=CHANGEME-ARGON2-PHC-STRING

# SQLite on the container volume; nightly backup to NAS + R2.
DATABASE_URL=data/db.sqlite3

# Signups disabled — Tom provisions each account manually via /admin until the
# Purelymail SMTP relay lands and INVITATIONS_ALLOWED can flip back to true.
SIGNUPS_ALLOWED=false
SIGNUPS_VERIFY=false
INVITATIONS_ALLOWED=false
INVITATION_ORG_NAME=Sodimo

# WebSocket notifications for live sync (Caddy proxies /notifications/hub).
WEBSOCKET_ENABLED=true

# --- SMTP (Purelymail outbound relay, post-cutover) -------------------------
# Stub block: uncomment + populate at the Purelymail email cutover. Until then
# Vaultwarden has no outbound mail and INVITATIONS_ALLOWED stays false.
# See `project_sodimo_email_arch` (Apr 29 hybrid Purelymail decision).
# SMTP_HOST=smtp.purelymail.com
# SMTP_PORT=587
# SMTP_FROM=vaultwarden@sodimo.eu
# SMTP_FROM_NAME=Sodimo Vault
# SMTP_USERNAME=vaultwarden@sodimo.eu
# SMTP_PASSWORD=CHANGEME-PURELYMAIL-APP-PASSWORD
# SMTP_SECURITY=starttls

# Sensible defaults
ROCKET_PORT=80
ROCKET_WORKERS=10
LOG_LEVEL=warn
