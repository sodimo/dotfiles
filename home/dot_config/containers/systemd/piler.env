# Piler — email archive frontend env.
# Paired with piler-mysql sidecar (see piler-mysql.container). Piler expects
# the MySQL hostname via MYSQL_HOSTNAME; without it, the entrypoint loops on
# `MYSQL localhost not ready` forever (see sodimo/dotfiles#17).
PILER_HOSTNAME=archive.sodimo.eu
PILER_HOST=archive.sodimo.eu
MYSQL_HOSTNAME=piler-mysql
MYSQL_DATABASE=piler
MYSQL_USER=piler
MYSQL_PASSWORD=CHANGEME-PILER-DB-PASSWORD
MYSQL_ROOT_PASSWORD=CHANGEME-PILER-ROOT-PASSWORD
MEMCACHED_ENABLED=1
