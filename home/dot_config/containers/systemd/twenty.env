# Twenty CRM — Sodimo config (v2.0.0)
#
# 2026-05-05: SERVER_URL / FRONT_BASE_URL pinned to https://crm.sodimo.eu
# (the eventual production URL once cloudflared + CF Access front the box).
# On the live demo box these are overridden to http://sodimo:3333 (Tom's
# Tailscale path) — that override stays out of the repo so chezmoi update
# does not flip the production URL back. PUBLIC_URL prep block below adds
# a commented LAN/Tailscale alternative for cutover-time clarity.
#
# REVERT TO LAN-DEMO POSTURE (rare; only if cloudflared has to come down):
#   SERVER_URL=http://192.168.0.134:3333
#   FRONT_BASE_URL=http://192.168.0.134:3333
#   AUTH_GOOGLE_ENABLED=false   # Google callback URL would be unreachable

NODE_ENV=production
NODE_PORT=3000
SERVER_URL=https://crm.sodimo.eu
# PUBLIC_URL prep — operator uncomments after cloudflared + CF Access land
# (issue #22). The hostname-only ALLOWLIST below already includes both shapes.
# SERVER_URL=http://192.168.0.134:3333
FRONT_BASE_URL=https://crm.sodimo.eu
# FRONT_BASE_URL=http://192.168.0.134:3333

# Hostname allowlist superset: both LAN IP and *.sodimo.eu (hostname-only,
# no port — same constraint as Paperclip's PAPERCLIP_ALLOWED_HOSTNAMES).
# Twenty's internal CSRF / origin checks read from FRONT_BASE_URL primarily;
# this list is the explicit superset for any host header Twenty receives.
TRUSTED_ORIGINS=https://crm.sodimo.eu,http://192.168.0.134:3333,http://sodimo:3333,http://localhost:3333

# Postgres + Redis
PG_DATABASE_URL=postgres://twenty:twenty@twenty-db:5432/default
REDIS_URL=redis://twenty-redis:6379

# App secrets (replace at apply time via `vault-fetch twenty`)
APP_SECRET=CHANGEME-REPLACE-AT-APPLY
MESSAGE_QUEUE_TYPE=bull-mq

# Auth — Google Workspace SSO. CF Access gates at edge; Twenty SSO means
# same identity once in. Day-one users: Rani, Paul, Michel, Tom.
AUTH_GOOGLE_ENABLED=true
AUTH_GOOGLE_CLIENT_ID=CHANGEME-GOOGLE-CLIENT-ID
AUTH_GOOGLE_CLIENT_SECRET=CHANGEME-GOOGLE-CLIENT-SECRET
AUTH_GOOGLE_CALLBACK_URL=https://crm.sodimo.eu/auth/google/redirect

# --- IMAP / SMTP (Twenty's bidirectional email sync) ------------------------
# IMAP and SMTP both flow through the Purelymail relay post-cutover (Apr 29
# hybrid Purelymail decision; the in-house Postfix + Dovecot path is retired).
# Until cutover, EMAIL_SMTP_* point at commented-out stubs and Twenty refuses
# to send notification mail; IMAP sync stays disabled per-message-account.
IS_IMAP_SMTP_CALDAV_ENABLED=true
MESSAGING_PROVIDER_IMAP_ENABLED=true
EMAIL_DRIVER=smtp
# EMAIL_SMTP_HOST=smtp.purelymail.com
# EMAIL_SMTP_PORT=587
# EMAIL_SMTP_USER=notifications@sodimo.eu
# EMAIL_SMTP_PASSWORD=CHANGEME-PURELYMAIL-APP-PASSWORD
# EMAIL_FROM_ADDRESS=notifications@sodimo.eu
# EMAIL_FROM_NAME=Sodimo CRM

# Storage — local for now; R2 later.
STORAGE_TYPE=local

# Telemetry opt-out
TELEMETRY_ENABLED=false
