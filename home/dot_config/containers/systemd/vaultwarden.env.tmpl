# Vaultwarden — Sodimo posture
DOMAIN=https://vault.sodimo.eu

# Admin UI (seeded token; rotate after first unlock)
ADMIN_TOKEN=CHANGEME-ADMIN-TOKEN-64CHAR

# SQLite on the container volume; nightly backup to NAS + R2
DATABASE_URL=data/db.sqlite3

# Signups disabled — Tom provisions each account manually.
SIGNUPS_ALLOWED=false
SIGNUPS_VERIFY=false
INVITATIONS_ALLOWED=true
INVITATION_ORG_NAME=Sodimo

# WebSocket notifications for live sync
WEBSOCKET_ENABLED=true

# SMTP via our own Postfix for invitations + password-reset emails
SMTP_HOST=postfix
SMTP_PORT=587
SMTP_FROM=admin@sodimo.eu
SMTP_FROM_NAME=Sodimo Vault
SMTP_USERNAME=admin@sodimo.eu
SMTP_PASSWORD=CHANGEME-SMTP-PASSWORD
SMTP_SECURITY=starttls

# Sensible defaults
ROCKET_PORT=80
ROCKET_WORKERS=10
LOG_LEVEL=warn
