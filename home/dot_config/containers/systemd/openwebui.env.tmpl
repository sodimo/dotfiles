# OpenWebUI — Sodimo posture (D-097, D-098)
# =============================================================================
# Auth is intentionally OFF. Access is gated at the Cloudflare edge by CF
# Access against Google Workspace; the tunnel only exposes the OWUI hostname
# to authenticated employees. Inside OWUI every session is admin — no
# forgotten-password tickets, no provisioning, no per-user workspace dance.
WEBUI_AUTH=false
ENABLE_SIGNUP=false
ENABLE_LOGIN_FORM=false
DEFAULT_USER_ROLE=admin
ENABLE_COMMUNITY_SHARING=false
ENABLE_USER_WEBHOOKS=false

# Replace at chezmoi apply time with a cryptographically-random 64-char value.
WEBUI_SECRET_KEY=CHANGEME-REPLACE-AT-PROVISION

WEBUI_NAME=Sodimo AI
WEBUI_URL=https://chat.sodimo.eu

# Postgres backing store (isolated per-service db per leger-labs pattern)
DATABASE_URL=postgresql://openwebui:openwebui@openwebui-db:5432/openwebui

# Redis (websocket support, sessions)
ENABLE_WEBSOCKET_SUPPORT=true
WEBSOCKET_REDIS_URL=redis://openwebui-redis:6379/0

# Models served by LiteLLM (single upstream; LiteLLM routes to llama-swap
# for local tiers and to Anthropic/OpenAI for cloud escalation).
OPENAI_API_BASE_URL=http://litellm:4000
OPENAI_API_KEY=CHANGEME-LITELLM-MASTER-KEY

# Disable features that don't fit the Sodimo posture.
ENABLE_OPENAI_API=true
ENABLE_OLLAMA_API=false
ENABLE_IMAGE_GENERATION=false
ENABLE_RAG_WEB_SEARCH=false
AUDIO_STT_ENGINE=
AUDIO_TTS_ENGINE=

# RAG embeddings routed through LiteLLM → llama-swap → qwen3-embedding.
# Prevents OWUI's default HuggingFace embed-model fetch at first boot.
RAG_EMBEDDING_ENGINE=openai
RAG_EMBEDDING_MODEL=local-embeddings
RAG_OPENAI_API_BASE_URL=http://litellm:4000
RAG_OPENAI_API_KEY=CHANGEME-LITELLM-MASTER-KEY

# Telemetry opt-out
SCARF_NO_ANALYTICS=true
DO_NOT_TRACK=true
ANONYMIZED_TELEMETRY=false

LOG_LEVEL=INFO
