# chezmoi data — Sodimo harness.
# =============================================================================
# Secrets used to live in age-encrypted files keyed off the recipient below,
# rendered into *.env.tmpl files by chezmoi at apply time. That path was never
# lit (#24): the .tmpl files have no `{{ }}` directives, real secrets are
# hand-edited on the box, and the recipient was a perpetual placeholder. The
# templating layer has been retired in favour of `vault-fetch` (#25), which
# pulls real values from Vaultwarden into ~/.config/sodimo/<service>.env at
# deploy time.
#
# This file is now reduced to non-secret operator/network metadata that
# chezmoi may reference if the renderer is ever re-introduced; it is not
# load-bearing for any currently-rendered file.

data:
  user:
    name: "sodimo"
    email: "admin@sodimo.eu"

  system:
    hostname: "{{ .chezmoi.hostname }}"
    os: "{{ .chezmoi.os }}"
    timezone: "Europe/Paris"

  network:
    name: "sodimo"
    subnet: "10.89.0.0/24"
    gateway: "10.89.0.1"

  cloudflare:
    # Real values written at `chezmoi init` time on the harness from the CF
    # dashboard; do NOT check in real values.
    tunnel_id: "PLACEHOLDER-REPLACE-AT-APPLY"
    account_id: "PLACEHOLDER-REPLACE-AT-APPLY"
    zone: "sodimo.eu"

  tailscale:
    tailnet: "PLACEHOLDER.ts.net"
    node: "harness"
